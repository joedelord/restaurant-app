#: .\backend\api\permissions.py:28 .\backend\api\permissions.py:40
msgid "You do not have permission to perform this action."
msgstr "Sinulla ei ole oikeutta suorittaa tätä toimintoa."

#: .\backend\api\permissions.py:60
msgid "You do not have permission to access this resource."
msgstr "Sinulla ei ole oikeutta käyttää tätä resurssia."

#: .\backend\api\serializers\order.py:65
msgid "Selected menu item is not available."
msgstr "Valittu ruoka-annos ei ole saatavilla."

#: .\backend\api\serializers\order.py:97
#: .\backend\api\serializers\reservation.py:99
msgid "Selected table is not active."
msgstr "Valittu pöytä ei ole aktiivinen."

#: .\backend\api\serializers\order.py:105
msgid "You are not allowed to set order status."
msgstr "Sinulla ei ole oikeutta asettaa tilauksen tilaa."

#: .\backend\api\serializers\order.py:108
#: .\backend\api\serializers\order.py:216
#: .\backend\api\serializers\order.py:241
msgid "Invalid order status."
msgstr "Virheellinen tilauksen tila."

#: .\backend\api\serializers\order.py:114
#: .\backend\api\serializers\order.py:140
#: .\backend\api\serializers\order.py:247
msgid "Order must contain at least one item."
msgstr "Tilauksen on sisällettävä vähintään yksi tuote."

#: .\backend\api\serializers\order.py:122
#: .\backend\api\serializers\order.py:255
msgid "Duplicate menu items are not allowed. Combine quantities into one row."
msgstr ""
"Samoja ruoka-annoksia ei saa olla usealla rivillä. Yhdistä määrät samalle "
"riville."

#: .\backend\api\serializers\order.py:135
#: .\backend\api\serializers\reservation.py:95
msgid "Table is required."
msgstr "Pöytä on pakollinen."

#: .\backend\api\serializers\order.py:149
msgid "Selected table does not match the reservation table."
msgstr "Valittu pöytä ei vastaa varauksen pöytää."

#: .\backend\api\serializers\order.py:154
msgid "Cannot create an order for this reservation."
msgstr "Tälle varaukselle ei voida luoda tilausta."

#: .\backend\api\serializers\order.py:159
msgid "An order already exists for this reservation."
msgstr "Tälle varaukselle on jo olemassa tilaus."

#: .\backend\api\serializers\order.py:212
#: .\backend\api\serializers\order.py:237
msgid "You are not allowed to update order status."
msgstr "Sinulla ei ole oikeutta päivittää tilauksen tilaa."

#: .\backend\api\serializers\order.py:269
msgid "Paid or cancelled orders cannot be edited."
msgstr "Maksettua tai peruttua tilausta ei voi muokata."

#: .\backend\api\serializers\reservation.py:52
msgid "Party size must be greater than zero."
msgstr "Henkilömäärän on oltava suurempi kuin nolla."

#: .\backend\api\serializers\reservation.py:57
msgid "Reservation time cannot be in the past."
msgstr "Varausaika ei voi olla menneisyydessä."

#: .\backend\api\serializers\reservation.py:69
#: .\backend\api\serializers\reservation.py:172
msgid "Invalid reservation status."
msgstr "Virheellinen varauksen tila."

#: .\backend\api\serializers\reservation.py:74
msgid "You are not allowed to set this reservation status."
msgstr "Sinulla ei ole oikeutta asettaa tätä varaustilaa."

#: .\backend\api\serializers\reservation.py:104
msgid "Party size exceeds the number of seats at this table."
msgstr "Henkilömäärä ylittää pöydän istumapaikkojen määrän."

#: .\backend\api\serializers\reservation.py:114
msgid "You cannot modify a confirmed or completed reservation."
msgstr "Et voi muokata vahvistettua tai päättynyttä varausta."

#: .\backend\api\serializers\reservation.py:121
#: .\backend\api\serializers\reservation.py:176
msgid "You may only cancel your reservation."
msgstr "Voit ainoastaan perua oman varauksesi."

#: .\backend\api\serializers\reservation.py:127
msgid "New reservations are created with pending status only."
msgstr "Uudet varaukset luodaan aina odottava-tilassa."

#: .\backend\api\serializers\reservation.py:150
msgid "This table is not available at the selected time."
msgstr "Tämä pöytä ei ole saatavilla valittuna ajankohtana."

#: .\backend\api\serializers\reservation.py:168
msgid "Authentication required."
msgstr "Tunnistautuminen vaaditaan."

#: .\backend\api\serializers\user.py:87
msgid "Invalid email or password."
msgstr "Virheellinen sähköposti tai salasana."

#: .\backend\api\serializers\user.py:131
msgid "Current password is incorrect."
msgstr "Nykyinen salasana on virheellinen."

#: .\backend\api\serializers\user.py:138
msgid "Passwords do not match."
msgstr "Salasanat eivät täsmää."

#: .\backend\api\serializers\user.py:145
msgid "New password must be different from the current password."
msgstr "Uuden salasanan täytyy olla eri kuin nykyinen salasana."

#: .\backend\api\utils\emails.py:24
msgid "A user with this email already exists."
msgstr "Käyttäjä tällä sähköpostiosoitteella on jo olemassa."

#: .\backend\api\utils\names.py:26
msgid "First name is required."
msgstr "Etunimi on pakollinen."

#: .\backend\api\utils\names.py:31
msgid "First name must contain at least 2 characters."
msgstr "Etunimen täytyy sisältää vähintään 2 merkkiä."

#: .\backend\api\utils\names.py:36
msgid "First name can only contain letters, spaces, hyphens and apostrophes."
msgstr ""
"Etunimi voi sisältää vain kirjaimia, välilyöntejä, yhdysmerkkejä ja "
"heittomerkkejä."

#: .\backend\api\utils\names.py:51
msgid "Last name is required."
msgstr "Sukunimi on pakollinen."

#: .\backend\api\utils\names.py:56
msgid "Last name must contain at least 2 characters."
msgstr "Sukunimen täytyy sisältää vähintään 2 merkkiä."

#: .\backend\api\utils\names.py:61
msgid "Last name can only contain letters, spaces, hyphens and apostrophes."
msgstr ""
"Sukunimi voi sisältää vain kirjaimia, välilyöntejä, yhdysmerkkejä ja "
"heittomerkkejä."

#: .\backend\api\utils\passwords.py:26
msgid "Password must contain at least 8 characters."
msgstr "Salasanan täytyy sisältää vähintään 8 merkkiä."

#: .\backend\api\utils\passwords.py:31
msgid "Password must contain at least one uppercase letter."
msgstr "Salasanan täytyy sisältää vähintään yksi iso kirjain."

#: .\backend\api\utils\passwords.py:36
msgid "Password must contain at least one number."
msgstr "Salasanan täytyy sisältää vähintään yksi numero."

#: .\backend\api\utils\phones.py:30
msgid "Phone number can only contain numbers, spaces, +, -, ( and )."
msgstr ""
"Puhelinnumero voi sisältää vain numeroita, välilyöntejä sekä merkit +, -, "
"( ja )."

#: .\backend\api\utils\phones.py:37
msgid "Phone number must contain 7-15 digits."
msgstr "Puhelinnumerossa täytyy olla 7–15 numeroa."

#: .\backend\api\views\auth.py:46
msgid "Refresh token is required."
msgstr "Refresh token on pakollinen."

#: .\backend\api\views\auth.py:54
msgid "Successfully logged out."
msgstr "Uloskirjautuminen onnistui."

#: .\backend\api\views\auth.py:59
msgid "Invalid or expired refresh token."
msgstr "Virheellinen tai vanhentunut refresh token."

#: .\backend\api\views\orders.py:67
msgid "Served or paid orders cannot be deleted."
msgstr "Tarjoiltua tai maksettua tilausta ei voi poistaa."

#: .\backend\api\views\orders.py:73
msgid "Order deleted successfully."
msgstr "Tilaus poistettu onnistuneesti."

#: .\backend\api\views\reservations.py:66
msgid "date is required."
msgstr "Päivämäärä on pakollinen."

#: .\backend\api\views\reservations.py:69
msgid "party_size is required."
msgstr "Henkilömäärä on pakollinen."

#: .\backend\api\views\reservations.py:77
msgid "party_size must be a positive integer."
msgstr "Henkilömäärän on oltava positiivinen kokonaisluku."

#: .\backend\api\views\reservations.py:83
msgid "Invalid date format."
msgstr "Virheellinen päivämäärämuoto."

#: .\backend\api\views\users.py:43
msgid "Password changed successfully."
msgstr "Salasana vaihdettu onnistuneesti."
